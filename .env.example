# Database Connection (Same as Vercel)
DATABASE_URL=postgres://user:password@hostname:5432/dbname

# AI Key (Get for free from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Facebook Graph API (For posting to Facebook Page & IG)
FB_PAGE_ID=your_facebook_page_id
FB_ACCESS_TOKEN=your_facebook_page_access_token

# LINE Messaging API (For broadcasting to LINE OA)
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token

# X (Twitter) API Keys (If needed later)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
